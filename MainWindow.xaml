<Window x:Class="CustomClipboardManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CustomClipboardManager"
        mc:Ignorable="d"
        Title="Clipboard Manager" Height="550" Width="400" MinWidth="300" MinHeight="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" ResizeMode="CanResizeWithGrip"
        Topmost="True" ShowInTaskbar="False"
        KeyDown="Window_KeyDown" Deactivated="MainWindow_Deactivated"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <!-- Fonts -->
        <FontFamily x:Key="IconFont">Segoe MDL2 Assets, Segoe Fluent Icons</FontFamily>

        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:ThemeIconConverter x:Key="ThemeIconConverter"/>

        <!-- Context Menu Style -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="2"/>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Padding="15,8" Background="{TemplateBinding Background}">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ElementHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextFaintBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Invisible ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="Transparent" />
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb Background="{DynamicResource ScrollBarThumbBrush}" Margin="0" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search TextBox Style -->
        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SearchBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SearchForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchBorderBrush}"/>
            <Setter Property="Padding" Value="35,10,10,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="{DynamicResource SearchCaretBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="12">
                            <Grid>
                                <TextBlock Text="&#xE721;" FontFamily="{StaticResource IconFont}" 
                                           Foreground="{DynamicResource TextMutedBrush}" FontSize="14"
                                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SearchFocusedBackgroundBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource SearchFocusedBorderBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- IconButton Style -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ElementHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextForegroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ElementPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Filter Toggle Style -->
        <Style x:Key="FilterToggleStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource FilterForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource FilterBorderBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource FilterHoverBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource FilterHoverForegroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource FilterCheckedBackgroundBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource FilterCheckedBorderBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource FilterCheckedForegroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="MainBorder" Background="{DynamicResource AppBackgroundBrush}" CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource AppBorderBrush}" Margin="15" Opacity="0">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="30" Opacity="0.8" Direction="270" ShadowDepth="10"/>
        </Border.Effect>
        <Grid>
            <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Header & Filters -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Traffic Lights (Red Only, when pinned) -->
                    <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,15,0"
                                Visibility="{Binding IsWindowPinned, Converter={StaticResource BoolToVis}}">
                        <Button Width="12" Height="12" ToolTip="Close" BorderThickness="0" Background="#FF5F56" Click="TrafficRed_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" BorderBrush="#E0443E" BorderThickness="1"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <!-- Search Box -->
                    <Grid Grid.Column="1" HorizontalAlignment="Left" Width="220">
                        <TextBox x:Name="SearchBox" Style="{StaticResource SearchTextBoxStyle}"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewKeyDown="SearchBox_PreviewKeyDown"/>
                        <TextBlock Text="Search clipboard..." Foreground="{DynamicResource TextMutedBrush}" IsHitTestVisible="False"
                                   VerticalAlignment="Center" Margin="36,0,0,0" FontSize="14">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Header Tools -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Command="{Binding RequestConfirmClearAllCommand}" Style="{StaticResource IconButtonStyle}" ToolTip="Clear All" Foreground="#FF3B30" Margin="0,0,5,0">
                            <TextBlock Text="&#xE74D;" FontFamily="{StaticResource IconFont}" FontSize="16"/>
                        </Button>
                        <!-- Pin Button -->
                        <ToggleButton x:Name="PinButton" Command="{Binding TogglePinWindowCommand}" IsChecked="{Binding IsWindowPinned, Mode=OneWay}" ToolTip="Pin Window" Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Padding="8">
                                        <TextBlock x:Name="Icon" Text="&#xE840;" FontFamily="{StaticResource IconFont}" FontSize="18" Foreground="{DynamicResource TextMutedBrush}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Icon" Property="Text" Value="&#xE840;"/>
                                            <Setter TargetName="Icon" Property="Foreground" Value="#0078D7"/>
                                            <Setter TargetName="Bd" Property="Background" Value="#330078D7"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ElementHoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <!-- Theme Button -->
                        <Button Command="{Binding ToggleThemeCommand}" Style="{StaticResource IconButtonStyle}" ToolTip="Toggle Theme" Foreground="{DynamicResource TextForegroundBrush}" Margin="0,0,5,0">
                            <TextBlock Text="{Binding IsDarkMode, Converter={StaticResource ThemeIconConverter}}" FontFamily="{StaticResource IconFont}" FontSize="18"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Filters -->
                <ScrollViewer x:Name="FilterScrollViewer" Grid.Row="1" Margin="10,0,10,0" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" PanningMode="HorizontalOnly" PreviewMouseWheel="FilterScrollViewer_PreviewMouseWheel">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <RadioButton Content="All" IsChecked="True" Style="{StaticResource FilterToggleStyle}" Command="{Binding FilterTypeCommand}" CommandParameter="All"/>
                        <RadioButton Content="Pinned" Style="{StaticResource FilterToggleStyle}" Command="{Binding FilterTypeCommand}" CommandParameter="Pinned"/>
                        <RadioButton Content="Texts" Style="{StaticResource FilterToggleStyle}" Command="{Binding FilterTypeCommand}" CommandParameter="Text"/>
                        <RadioButton Content="Images" Style="{StaticResource FilterToggleStyle}" Command="{Binding FilterTypeCommand}" CommandParameter="Image"/>
                        <RadioButton Content="Links" Style="{StaticResource FilterToggleStyle}" Command="{Binding FilterTypeCommand}" CommandParameter="Link"/>
                        <RadioButton Content="Files" Style="{StaticResource FilterToggleStyle}" Command="{Binding FilterTypeCommand}" CommandParameter="Files"/>
                        <RadioButton Content="Colors" Style="{StaticResource FilterToggleStyle}" Command="{Binding FilterTypeCommand}" CommandParameter="ColorCode"/>
                        <RadioButton Content="Code" Style="{StaticResource FilterToggleStyle}" Command="{Binding FilterTypeCommand}" CommandParameter="Code"/>
                        <RadioButton Content="Others" Style="{StaticResource FilterToggleStyle}" Command="{Binding FilterTypeCommand}" CommandParameter="Others"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Empty State -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ClipboardItemsView.IsEmpty}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="&#xE81C;" FontFamily="{StaticResource IconFont}" FontSize="64" Foreground="{DynamicResource TextFaintBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="Your clipboard is empty" Foreground="{DynamicResource TextMutedBrush}" FontSize="16" Margin="0,15,0,0" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                <TextBlock Text="Copy some text or images to see them here" Foreground="{DynamicResource TextFaintBrush}" FontSize="12" Margin="0,5,0,0" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Item List -->
            <ListView x:Name="ItemsListView" Grid.Row="1" ItemsSource="{Binding ClipboardItemsView}" 
                      Background="Transparent" BorderThickness="0" 
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      AlternationCount="9"
                      PreviewMouseLeftButtonDown="ItemsListView_PreviewMouseLeftButtonDown"
                      PreviewMouseMove="ItemsListView_PreviewMouseMove">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Margin" Value="0,0,0,8"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" 
                                            CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource ListViewItemBorderBrush}" Padding="12">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ListViewItemHoverBackgroundBrush}"/>
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource ListViewItemHoverBorderBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Background="Transparent">
                            <Grid.InputBindings>
                                <MouseBinding Gesture="LeftClick" Command="{Binding DataContext.PasteItemCommand, RelativeSource={RelativeSource AncestorType=ListView}}" CommandParameter="{Binding}" />
                            </Grid.InputBindings>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Header -->
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Hotkey Hint & Category -->
                                <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                                    <Border Background="{DynamicResource ElementBackgroundBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                        <TextBlock Foreground="{DynamicResource TextMutedBrush}" FontSize="11" FontWeight="SemiBold">
                                            <TextBlock.Text>
                                                <Binding RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}" Path="(ItemsControl.AlternationIndex)" StringFormat="[ {0} ]"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <!-- Only show 0-8 (which maps to 1-9) -->
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=(ItemsControl.AlternationIndex)}" Value="0"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=(ItemsControl.AlternationIndex)}" Value="1"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=(ItemsControl.AlternationIndex)}" Value="2"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=(ItemsControl.AlternationIndex)}" Value="3"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=(ItemsControl.AlternationIndex)}" Value="4"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=(ItemsControl.AlternationIndex)}" Value="5"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=(ItemsControl.AlternationIndex)}" Value="6"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=(ItemsControl.AlternationIndex)}" Value="7"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListViewItem}}, Path=(ItemsControl.AlternationIndex)}" Value="8"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    
                                    <Border x:Name="CategoryBadge" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding Category}" Foreground="{DynamicResource TextForegroundBrush}" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                    <TextBlock Text="{Binding MetadataText}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding TimeAgo}" Foreground="{DynamicResource TextFaintBrush}" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Actions -->
                                <StackPanel Orientation="Horizontal" Grid.Column="2">
                                    <Button Command="{Binding DataContext.CopyOnlyCommand, RelativeSource={RelativeSource AncestorType=ListView}}" CommandParameter="{Binding}"
                                            Style="{StaticResource IconButtonStyle}" ToolTip="Copy without pasting" Margin="0,0,2,0">
                                        <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource IconFont}" FontSize="14"/>
                                    </Button>

                                    <Button Command="{Binding DataContext.PinItemCommand, RelativeSource={RelativeSource AncestorType=ListView}}" CommandParameter="{Binding}"
                                            Style="{StaticResource IconButtonStyle}" ToolTip="Pin item" Margin="0,0,2,0">
                                        <TextBlock Text="&#xE718;" FontFamily="{StaticResource IconFont}" FontSize="14">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                            <Setter Property="Foreground" Value="#FFAA00"/>
                                                            <Setter Property="Text" Value="&#xE840;"/> <!-- Pinned solid icon -->
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Button>

                                    <Button Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=ListView}}" CommandParameter="{Binding}"
                                            Style="{StaticResource IconButtonStyle}" ToolTip="Delete item">
                                        <TextBlock Text="&#xE74D;" FontFamily="{StaticResource IconFont}" FontSize="14"/>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <!-- Content Area -->
                            <Grid Grid.Row="1" Margin="0,5,0,0">
                                <TextBlock Text="{Binding DisplayText}" TextWrapping="Wrap" Foreground="{DynamicResource TextForegroundBrush}" FontSize="13" MaxHeight="60" TextTrimming="CharacterEllipsis">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ContentType}" Value="Text">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Border CornerRadius="6" HorizontalAlignment="Left" ClipToBounds="True">
                                    <Image Source="{Binding ImageContent}" MaxHeight="120" Stretch="Uniform">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ContentType}" Value="Image">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Border>
                            </Grid>
                        </Grid>

                        <DataTemplate.Triggers>
                            <!-- Dynamic Category Colors -->
                            <DataTrigger Binding="{Binding Category}" Value="Text">
                                <Setter TargetName="CategoryBadge" Property="Background" Value="{DynamicResource ElementBackgroundBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Category}" Value="Link">
                                <Setter TargetName="CategoryBadge" Property="Background" Value="#330078D7"/>
                                <Setter TargetName="CategoryBadge" Property="BorderThickness" Value="1"/>
                                <Setter TargetName="CategoryBadge" Property="BorderBrush" Value="#660078D7"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Category}" Value="ColorCode">
                                <Setter TargetName="CategoryBadge" Property="Background" Value="#33107C10"/>
                                <Setter TargetName="CategoryBadge" Property="BorderThickness" Value="1"/>
                                <Setter TargetName="CategoryBadge" Property="BorderBrush" Value="#66107C10"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Category}" Value="Image">
                                <Setter TargetName="CategoryBadge" Property="Background" Value="#33D24726"/>
                                <Setter TargetName="CategoryBadge" Property="BorderThickness" Value="1"/>
                                <Setter TargetName="CategoryBadge" Property="BorderBrush" Value="#66D24726"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Overlays -->
        <Grid x:Name="ToastGrid" Opacity="0" IsHitTestVisible="False" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,30">
            <Border Background="#CC000000" CornerRadius="20" Padding="15,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8FB;" FontFamily="{StaticResource IconFont}" Foreground="#00CC00" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Copied!" Foreground="{DynamicResource TextForegroundBrush}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="ConfirmGrid" Visibility="Collapsed" Background="#B2000000">
            <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="8" Padding="20" HorizontalAlignment="Center" VerticalAlignment="Center" BorderThickness="1" BorderBrush="{DynamicResource AppBorderBrush}">
                <StackPanel>
                    <TextBlock Text="Clear All History?" Foreground="{DynamicResource TextForegroundBrush}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="This will remove all unpinned items. This action cannot be undone." Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Width="200" TextAlignment="Center" Margin="0,0,0,20"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Cancel" Click="ConfirmNo_Click" Background="{DynamicResource ElementBackgroundBrush}" Foreground="{DynamicResource TextForegroundBrush}" Padding="15,8" Margin="0,0,10,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/></Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="Clear All" Click="ConfirmYes_Click" Background="#FF3333" Foreground="{DynamicResource TextForegroundBrush}" Padding="15,8">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/></Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        </Grid>
    </Border>
</Window>
