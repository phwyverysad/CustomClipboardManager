<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#E6FFFFFF"/>
    <SolidColorBrush x:Key="AppBorderBrush" Color="#33000000"/>
    <SolidColorBrush x:Key="TextForegroundBrush" Color="#222222"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#66222222"/>
    <SolidColorBrush x:Key="TextFaintBrush" Color="#44222222"/>
    <SolidColorBrush x:Key="ElementBackgroundBrush" Color="#1A000000"/>
    <SolidColorBrush x:Key="ElementHoverBrush" Color="#33000000"/>
    <SolidColorBrush x:Key="ElementPressedBrush" Color="#4D000000"/>
    
    <Color x:Key="DropShadowColor">#40000000</Color>

    <!-- Theme Control Brushes -->
    <SolidColorBrush x:Key="SearchBackgroundBrush" Color="#12000000"/>
    <SolidColorBrush x:Key="SearchForegroundBrush" Color="#222222"/>
    <SolidColorBrush x:Key="SearchBorderBrush" Color="#1F000000"/>
    <SolidColorBrush x:Key="SearchCaretBrush" Color="#222222"/>
    <SolidColorBrush x:Key="SearchFocusedBackgroundBrush" Color="#1A000000"/>
    <SolidColorBrush x:Key="SearchFocusedBorderBrush" Color="#3A000000"/>

    <SolidColorBrush x:Key="FilterForegroundBrush" Color="#77222222"/>
    <SolidColorBrush x:Key="FilterBorderBrush" Color="#1F000000"/>
    <SolidColorBrush x:Key="FilterHoverBackgroundBrush" Color="#10000000"/>
    <SolidColorBrush x:Key="FilterHoverForegroundBrush" Color="#222222"/>
    <SolidColorBrush x:Key="FilterCheckedBackgroundBrush" Color="#22000000"/>
    <SolidColorBrush x:Key="FilterCheckedBorderBrush" Color="#44000000"/>
    <SolidColorBrush x:Key="FilterCheckedForegroundBrush" Color="#222222"/>

    <SolidColorBrush x:Key="ListViewItemBorderBrush" Color="#0D000000"/>
    <SolidColorBrush x:Key="ListViewItemHoverBackgroundBrush" Color="#10000000"/>
    <SolidColorBrush x:Key="ListViewItemHoverBorderBrush" Color="#22000000"/>
    
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#33000000"/>

    <!-- Context Menu Submenu Fixes (Overrides SystemColors) -->
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#F2FFFFFF"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBarBrushKey}" Color="#F2FFFFFF"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#222222"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#F2FFFFFF"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#222222"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#33000000"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#222222"/>
</ResourceDictionary>
